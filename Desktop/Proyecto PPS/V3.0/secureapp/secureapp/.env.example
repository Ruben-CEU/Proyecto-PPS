# =============================================================================
# Copia este fichero como .env y rellena con valores seguros ANTES de
# arrancar docker compose. Nunca subas .env a Git.
# =============================================================================

# MySQL
MYSQL_ROOT_PASSWORD=cambia_esto_root_seguro
MYSQL_DATABASE=secureapp
MYSQL_USER=appuser
MYSQL_PASSWORD=cambia_esto_appuser_seguro

# Backend JWT — genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_a_32_bytes_hex_aleatorio

# Frontend Flask session
FLASK_SECRET_KEY=cambia_esto_flask_secret_aleatorio
