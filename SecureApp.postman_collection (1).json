  "item": [
    {
      "name": "01 - Health Check",
      "item": [
        {
          "name": "GET /api/health — servicio OK",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/health",
            "description": "Verifica que el backend y MySQL están operativos"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status es ok', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.status).to.eql('ok');",
                  "    pm.expect(j.service).to.eql('backend-api');",
                  "    pm.expect(j.database).to.exist;",
                  "    pm.expect(j.engine).to.eql('MySQL 8');",
                  "});",
                  "pm.test('Content-Type es JSON', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Autenticación",
      "item": [
        {
          "name": "POST /api/login — admin correcto ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Devuelve token JWT válido (3 partes)', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.token).to.exist;",
                  "    pm.expect(j.token.split('.')).to.have.lengthOf(3);",
                  "    pm.expect(j.role).to.eql('admin');",
                  "    pm.expect(j.username).to.eql('admin');",
                  "});",
                  "// Guardar token en colección Y entorno",
                  "const j = pm.response.json();",
                  "if (j.token) {",
                  "    pm.collectionVariables.set('admin_token', j.token);",
                  "    pm.environment.set('admin_token', j.token);",
                  "}",
                  "pm.test('Token guardado correctamente', () => {",
                  "    pm.expect(pm.collectionVariables.get('admin_token')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": "{{base_url}}/api/login",
            "description": "Login administrador. Guarda el token automáticamente para los siguientes requests."
          }
        },
        {
          "name": "POST /api/login — usuario normal ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Rol es user', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.role).to.eql('user');",
                  "    pm.expect(j.username).to.eql('usuario');",
                  "});",
                  "const j = pm.response.json();",
                  "if (j.token) {",
                  "    pm.collectionVariables.set('user_token', j.token);",
                  "    pm.environment.set('user_token', j.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"usuario\",\n  \"password\": \"User1234!\"\n}"
            },
            "url": "{{base_url}}/api/login"
          }
        },
