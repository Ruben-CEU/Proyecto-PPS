            "url": "{{base_url}}/api/login",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"WRONG\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('No devuelve token', () => pm.expect(pm.response.json().token).to.not.exist);",
                  "pm.test('Mensaje de error presente', () => pm.expect(pm.response.json().error).to.exist);"
                ],
                "type": "text/javascript"
              }
