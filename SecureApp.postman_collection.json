    {
      "name": "06 - Cabeceras de Seguridad (OWASP A05)",
      "item": [
        {
          "name": "Verificar todas las cabeceras HTTP de seguridad",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('X-Frame-Options: DENY', () => {",
                  "    pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY');",
                  "});",
                  "pm.test('X-Content-Type-Options: nosniff', () => {",
                  "    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff');",
                  "});",
                  "pm.test('Cache-Control: no-store', () => {",
                  "    pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store');",
                  "});",
                  "pm.test('Content-Security-Policy presente', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Security-Policy')).to.include('default-src');",
                  "});",
                  "pm.test('Strict-Transport-Security presente', () => {",
                  "    pm.expect(pm.response.headers.get('Strict-Transport-Security')).to.include('max-age');",
                  "});",
                  "pm.test('Referrer-Policy presente', () => {",
                  "    pm.expect(pm.response.headers.get('Referrer-Policy')).to.exist;",
                  "});",
                  "pm.test('X-XSS-Protection presente', () => {",
                  "    pm.expect(pm.response.headers.get('X-XSS-Protection')).to.include('1');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health",
            "description": "Verifica las 7 cabeceras HTTP de seguridad requeridas por OWASP A05"
          }
        },
        {
          "name": "Cabeceras también presentes en respuestas de error",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('X-Frame-Options en error 401', () => {",
                  "    pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY');",
                  "});",
                  "pm.test('Cache-Control en error 401', () => {",
                  "    pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/profile",
            "description": "Las cabeceras de seguridad deben estar incluso en respuestas de error"
          }
        }
      ]
    }
  ]
}